&lt;li&gt;&lt;input disabled="" type="checkbox"&gt; Jana imbangan duga&lt;/li&gt;
&lt;li&gt;&lt;input disabled="" type="checkbox"&gt; Sediakan penyata kewangan&lt;/li&gt;
&lt;li&gt;&lt;input disabled="" type="checkbox"&gt; Semak varians&lt;/li&gt;
&lt;li&gt;&lt;input disabled="" type="checkbox"&gt; Pelaporan pengurusan&lt;/li&gt;
&lt;/ul&gt;
&lt;h2&gt;Amalan Terbaik&lt;span class="hx:absolute hx:-mt-20" id="amalan-terbaik"&gt;&lt;/span&gt;
&lt;a href="#amalan-terbaik" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;Mula awal&lt;/li&gt;
&lt;li&gt;Ikut senarai semak&lt;/li&gt;
&lt;li&gt;Dokumentasikan pengecualian&lt;/li&gt;
&lt;li&gt;Dapatkan kelulusan&lt;/li&gt;
&lt;/ul&gt;
&lt;hr&gt;
&lt;p&gt;&lt;em&gt;Muat turun templat senarai semak akhir bulan&lt;/em&gt;&lt;/p&gt;</description></item></channel></rss>