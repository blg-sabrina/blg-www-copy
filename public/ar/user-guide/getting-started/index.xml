&lt;h2&gt;خيارات النشر&lt;span class="hx:absolute hx:-mt-20" id="خيارات-النشر"&gt;&lt;/span&gt;
&lt;a href="#%d8%ae%d9%8a%d8%a7%d8%b1%d8%a7%d8%aa-%d8%a7%d9%84%d9%86%d8%b4%d8%b1" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h2&gt;&lt;h3&gt;النشر السحابي (موصى به)&lt;span class="hx:absolute hx:-mt-20" id="النشر-السحابي-موصى-به"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d9%86%d8%b4%d8%b1-%d8%a7%d9%84%d8%b3%d8%ad%d8%a7%d8%a8%d9%8a-%d9%85%d9%88%d8%b5%d9%89-%d8%a8%d9%87" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;h4&gt;السحابة العامة&lt;span class="hx:absolute hx:-mt-20" id="السحابة-العامة"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d8%b3%d8%ad%d8%a7%d8%a8%d8%a9-%d8%a7%d9%84%d8%b9%d8%a7%d9%85%d8%a9" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h4&gt;&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;مُدارة بواسطة BigLedger&lt;/strong&gt;: صفر أعباء على تقنية المعلومات&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;تحديثات تلقائية&lt;/strong&gt;: أحدث الميزات دائمًا&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;CDN عالمي&lt;/strong&gt;: وصول سريع في أي مكان&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;التسعير&lt;/strong&gt;: بدءًا من RM299/شهريًا&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;الأنسب لـ&lt;/strong&gt;: الشركات الصغيرة والمتوسطة، والشركات الناشئة، والأعمال النامية&lt;/li&gt;
&lt;/ul&gt;
&lt;h4&gt;السحابة الخاصة&lt;span class="hx:absolute hx:-mt-20" id="السحابة-الخاصة"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d8%b3%d8%ad%d8%a7%d8%a8%d8%a9-%d8%a7%d9%84%d8%ae%d8%a7%d8%b5%d8%a9" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h4&gt;&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;موارد مخصّصة&lt;/strong&gt;: خوادمك الخاصة&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;أمان معزّز&lt;/strong&gt;: بيئة معزولة&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;اتفاقيات مستوى خدمة (SLA) مخصّصة&lt;/strong&gt;: أداء مضمون&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;التسعير&lt;/strong&gt;: بدءًا من RM2,999/شهريًا&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;الأنسب لـ&lt;/strong&gt;: المؤسسات والبنوك والجهات الحكومية&lt;/li&gt;
&lt;/ul&gt;
&lt;h3&gt;النشر المحلي&lt;span class="hx:absolute hx:-mt-20" id="النشر-المحلي"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d9%86%d8%b4%d8%b1-%d8%a7%d9%84%d9%85%d8%ad%d9%84%d9%8a" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;h4&gt;الاستضافة الذاتية&lt;span class="hx:absolute hx:-mt-20" id="الاستضافة-الذاتية"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d8%a7%d8%b3%d8%aa%d8%b6%d8%a7%d9%81%d8%a9-%d8%a7%d9%84%d8%b0%d8%a7%d8%aa%d9%8a%d8%a9" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h4&gt;&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;تحكّم كامل&lt;/strong&gt;: بنيتك التحتية الخاصة&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;خيار معزول عن الشبكة&lt;/strong&gt;: لا يتطلّب اتصالًا بالإنترنت&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;التخصيص&lt;/strong&gt;: تعديلات غير محدودة&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;التسعير&lt;/strong&gt;: ترخيص لمرة واحدة + الصيانة&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;الأنسب لـ&lt;/strong&gt;: البيئات عالية الأمان، والجهات العسكرية، والعمليات البحرية&lt;/li&gt;
&lt;/ul&gt;
&lt;div class="hx:overflow-x-auto hx:mt-6 hx:flex hx:rounded-lg hx:border hx:py-2 hx:ltr:pr-4 hx:rtl:pl-4 hx:contrast-more:border-current hx:contrast-more:dark:border-current hx:border-orange-100 hx:bg-orange-50 hx:text-orange-800 hx:dark:border-orange-400/30 hx:dark:bg-orange-400/20 hx:dark:text-orange-300"&gt;
&lt;div class="hx:ltr:pl-3 hx:ltr:pr-2 hx:rtl:pr-3 hx:rtl:pl-2"&gt;&lt;/div&gt;
&lt;div class="hx:w-full hx:min-w-0 hx:leading-7"&gt;
&lt;div class="hx:mt-6 hx:leading-7 hx:first:mt-0"&gt;&lt;strong&gt;💡 توصية&lt;/strong&gt;: ابدأ بالسحابة العامة لأسرع نشر (يومان)، ثم انتقل إلى السحابة الخاصة أو النشر المحلي حسب الحاجة. يبقى 80% من العملاء على السحابة العامة.&lt;/div&gt;
&lt;/div&gt;
&lt;/div&gt;
&lt;h2&gt;قائمة التحقّق للبدء&lt;span class="hx:absolute hx:-mt-20" id="قائمة-التحقق-للبدء"&gt;&lt;/span&gt;
&lt;a href="#%d9%82%d8%a7%d8%a6%d9%85%d8%a9-%d8%a7%d9%84%d8%aa%d8%ad%d9%82%d9%82-%d9%84%d9%84%d8%a8%d8%af%d8%a1" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h2&gt;&lt;h3&gt;الأسبوع 1: التخطيط&lt;span class="hx:absolute hx:-mt-20" id="الأسبوع-1-التخطيط"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d8%a3%d8%b3%d8%a8%d9%88%d8%b9-1-%d8%a7%d9%84%d8%aa%d8%ae%d8%b7%d9%8a%d8%b7" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;&lt;input disabled="" type="checkbox"&gt; تحديد متطلبات العمل ونقاط الألم&lt;/li&gt;
&lt;li&gt;&lt;input disabled="" type="checkbox"&gt; اختيار خيار النشر (يُوصى بالسحابة)&lt;/li&gt;
&lt;li&gt;&lt;input disabled="" type="checkbox"&gt; اختيار الـ applets الأولية (ابدأ بـ 5-7)&lt;/li&gt;
