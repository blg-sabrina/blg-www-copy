&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/doc-item-maintenance-applet/" &gt;أبلت صيانة عناصر المستندات&lt;/a&gt;&lt;/strong&gt; - عناصر الخدمات والعناصر غير المخزونية&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/supplier-maintenance-applet/" &gt;أبلت صيانة المورّدين&lt;/a&gt;&lt;/strong&gt; - علاقات منتجات المورّدين&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/tax-configuration-applet/" &gt;أبلت تكوين الضرائب&lt;/a&gt;&lt;/strong&gt; - إعدادات ضرائب المنتجات&lt;/li&gt;
&lt;/ul&gt;
&lt;h3&gt;أبلتات إدارة المخزون&lt;span class="hx:absolute hx:-mt-20" id="أبلتات-إدارة-المخزون"&gt;&lt;/span&gt;
&lt;a href="#%d8%a3%d8%a8%d9%84%d8%aa%d8%a7%d8%aa-%d8%a5%d8%af%d8%a7%d8%b1%d8%a9-%d8%a7%d9%84%d9%85%d8%ae%d8%b2%d9%88%d9%86" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/stock-balance-applet/" &gt;أبلت رصيد المخزون&lt;/a&gt;&lt;/strong&gt; - مستويات المخزون في الوقت الفعلي&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/stock-take-applet/" &gt;أبلت جرد المخزون&lt;/a&gt;&lt;/strong&gt; - جرد المخزون المادي&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/internal-stock-adjustment-applet/" &gt;أبلت تسوية المخزون الداخلية&lt;/a&gt;&lt;/strong&gt; - تسويات المخزون&lt;/li&gt;
&lt;/ul&gt;
&lt;h3&gt;أبلتات التسعير والمبيعات&lt;span class="hx:absolute hx:-mt-20" id="أبلتات-التسعير-والمبيعات"&gt;&lt;/span&gt;
&lt;a href="#%d8%a3%d8%a8%d9%84%d8%aa%d8%a7%d8%aa-%d8%a7%d9%84%d8%aa%d8%b3%d8%b9%d9%8a%d8%b1-%d9%88%d8%a7%d9%84%d9%85%d8%a8%d9%8a%d8%b9%d8%a7%d8%aa" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
