&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;Parent&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;Global Holdings Inc. (HQ)&lt;/span&gt;
