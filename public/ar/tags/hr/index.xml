&lt;a href="#%d8%a3%d8%a8%d9%84%d8%aa%d8%a7%d8%aa-%d8%a7%d9%84%d9%88%d8%ad%d8%af%d8%a9-%d8%a7%d9%84%d8%a3%d8%b3%d8%a7%d8%b3%d9%8a%d8%a9" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/organization-applet/" &gt;أبلت المؤسسة&lt;/a&gt;&lt;/strong&gt; - هيكل الشركة والأقسام&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/tenant-admin-applet/" &gt;أبلت مسؤول المستأجر&lt;/a&gt;&lt;/strong&gt; - إدارة وصول المستخدمين&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/customer-maintenance-applet/" &gt;أبلت صيانة العملاء&lt;/a&gt;&lt;/strong&gt; - تعيينات مندوبي المبيعات&lt;/li&gt;
&lt;/ul&gt;
&lt;h3&gt;أبلتات الموارد البشرية والرواتب&lt;span class="hx:absolute hx:-mt-20" id="أبلتات-الموارد-البشرية-والرواتب"&gt;&lt;/span&gt;
&lt;a href="#%d8%a3%d8%a8%d9%84%d8%aa%d8%a7%d8%aa-%d8%a7%d9%84%d9%85%d9%88%d8%a7%d8%b1%d8%af-%d8%a7%d9%84%d8%a8%d8%b4%d8%b1%d9%8a%d8%a9-%d9%88%d8%a7%d9%84%d8%b1%d9%88%d8%a7%d8%aa%d8%a8" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/payroll-processing-applet/" &gt;أبلت معالجة الرواتب&lt;/a&gt;&lt;/strong&gt; - تعويضات الموظفين&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/time-attendance-applet/" &gt;أبلت الوقت والحضور&lt;/a&gt;&lt;/strong&gt; - تتبع وقت العمل&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/leave-management-applet/" &gt;أبلت إدارة الإجازات&lt;/a&gt;&lt;/strong&gt; - تتبع إجازات الموظفين&lt;/li&gt;
&lt;/ul&gt;
&lt;h3&gt;الأبلتات التشغيلية&lt;span class="hx:absolute hx:-mt-20" id="الأبلتات-التشغيلية"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d8%a3%d8%a8%d9%84%d8%aa%d8%a7%d8%aa-%d8%a7%d9%84%d8%aa%d8%b4%d8%ba%d9%8a%d9%84%d9%8a%d8%a9" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/project-team-applet/" &gt;أبلت فريق المشروع&lt;/a&gt;&lt;/strong&gt; - تعيينات المشاريع&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;&lt;a href="https://www.bigledger.com/ar/applets/sales-team-applet/" &gt;أبلت فريق المبيعات&lt;/a&gt;&lt;/strong&gt; - إدارة قوة المبيعات&lt;/li&gt;
