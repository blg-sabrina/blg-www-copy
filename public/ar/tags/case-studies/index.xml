&lt;h2&gt;الرعاية الصحية والطب&lt;span class="hx:absolute hx:-mt-20" id="الرعاية-الصحية-والطب"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d8%b1%d8%b9%d8%a7%d9%8a%d8%a9-%d8%a7%d9%84%d8%b5%d8%ad%d9%8a%d8%a9-%d9%88%d8%a7%d9%84%d8%b7%d8%a8" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h2&gt;&lt;h3&gt;العيادات والمراكز الطبية&lt;span class="hx:absolute hx:-mt-20" id="العيادات-والمراكز-الطبية"&gt;&lt;/span&gt;
&lt;a href="#%d8%a7%d9%84%d8%b9%d9%8a%d8%a7%d8%af%d8%a7%d8%aa-%d9%88%d8%a7%d9%84%d9%85%d8%b1%d8%a7%d9%83%d8%b2-%d8%a7%d9%84%d8%b7%d8%a8%d9%8a%d8%a9" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;p&gt;&lt;strong&gt;تحديات القطاع:&lt;/strong&gt;&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;إدارة سجلات المرضى والخصوصية&lt;/li&gt;
&lt;li&gt;جدولة المواعيد وتخصيص الموارد&lt;/li&gt;
&lt;li&gt;المخزون الطبي مع تتبّع الصلاحية&lt;/li&gt;
&lt;li&gt;معالجة مطالبات التأمين&lt;/li&gt;
&lt;li&gt;الامتثال التنظيمي وإعداد التقارير&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;strong&gt;حلول BigLedger:&lt;/strong&gt;&lt;/p&gt;
&lt;h4&gt;نظام إدارة الرعاية الصحية&lt;span class="hx:absolute hx:-mt-20" id="نظام-إدارة-الرعاية-الصحية"&gt;&lt;/span&gt;
&lt;a href="#%d9%86%d8%b8%d8%a7%d9%85-%d8%a5%d8%af%d8%a7%d8%b1%d8%a9-%d8%a7%d9%84%d8%b1%d8%b9%d8%a7%d9%8a%d8%a9-%d8%a7%d9%84%d8%b5%d8%ad%d9%8a%d8%a9" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h4&gt;&lt;div class="hextra-code-block hx:relative hx:mt-6 hx:first:mt-0 hx:group/code"&gt;
